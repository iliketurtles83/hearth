ANTHROPIC_API_KEY=your_key_here
OLLAMA_CHAT_MODEL=gemma4:e4b
OLLAMA_CODER_MODEL=qwen2.5-coder:14b
MODEL_CLOUD=claude-sonnet-4-20250514
CLOUD_THRESHOLD=300

CODE_INDEX_PATHS=backend frontend               # space-separated sub-paths to index (optional)
CODE_ENABLE_SHELL=false                         # set true to add ShellTool to ReAct agent
CODE_ENABLE_REPL=true

# User/audio
PUID=1000
PGID=1000
XDG_RUNTIME_DIR=/run/user/1000
PULSE_SOCKET=/run/user/1000/pulse/native

# Paths
MUSIC_PATH=/path/to/music
CODE_WORKSPACE_ROOT=/path/to/code-workspace
BEETS_DB_DIR=/path/to/beets/db
BEETS_DB_PATH=/beets/library.db
MUSIC_ROOT=/music

#CODING_AGENT_URL=http://localhost:3284        # AgentAPI server wrapping Aider or compatible agent
#CODING_AGENT_TIMEOUT_SECONDS=120              # Max seconds to wait for agent completion (default 120)
